# .env.example — Project Caravela
# Copy this file to .env and fill in real values before running any pipeline stage.
# NEVER commit .env to version control — it is listed in .gitignore.
# This file (.env.example) must remain committed with placeholder values only.

# ─── Google Cloud / BigQuery ────────────────────────────────────────────────
# Path to your GCP service account JSON key file (ASMP-015)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# GCP project ID — used by dbt profiles.yml and scripts/generate_parquet.py
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset names — do not rename without updating meltano.yml,
# dbt/profiles.yml, and scripts/generate_parquet.py.
# Pre-create both datasets before first run:
#   bq mk --dataset ${GCP_PROJECT_ID}:olist_raw
#   bq mk --dataset ${GCP_PROJECT_ID}:olist_analytics
BIGQUERY_RAW_DATASET=olist_raw
BIGQUERY_ANALYTICS_DATASET=olist_analytics

# ─── Dagster ────────────────────────────────────────────────────────────────
# Local directory for Dagster run history, logs, and schedule state.
# Keeps state project-local and separate from other Dagster projects.
# Create before first run: mkdir -p dagster_home
DAGSTER_HOME=./dagster_home
