digraph PipelineArchitectureDetailed {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=13, shape=box, style="rounded,filled", fillcolor="#f5f5f5", color="#333333"];
    edge [fontname="Helvetica", fontsize=10, color="#555555"];
    newrank=true;
    size="25.6,14.4!";
    ratio=fill;
    pad=0.4;
    nodesep=0.8;
    ranksep=1.0;
    splines=polyline;

    /* ══════════════════════════════════════════════════════════════
       RANK 0: Configuration
       ══════════════════════════════════════════════════════════════ */

    env [label=".env\nGOOGLE_APPLICATION_CREDENTIALS · GCP_PROJECT_ID\nBIGQUERY_ANALYTICS_DATASET · BIGQUERY_RAW_DATASET",
         fillcolor="#D7CCC8", shape=note, color="#8D6E63", fontsize=11];

    /* ══════════════════════════════════════════════════════════════
       RANK 1: Source → Ingestion
       ══════════════════════════════════════════════════════════════ */

    subgraph cluster_row1 {
        style=invis;

        csv [label="Source Layer — raw_data/\n9 CSV Files · ~1.1M rows total\n(geolocation: 1,000,163)", fillcolor="#FFF3E0", color="#E65100"];
        meltano [label="Ingestion — meltano/\nMeltano · tap-csv → target-bigquery\nbatch_job method", fillcolor="#E3F2FD", color="#1565C0"];
    }

    /* ══════════════════════════════════════════════════════════════
       RANK 2: BigQuery Raw
       ══════════════════════════════════════════════════════════════ */

    raw [label="BigQuery · olist_raw\n9 tables + 9 _view aliases · ~1.1M rows",
         fillcolor="#C5CAE9", color="#7986CB"];

    /* ══════════════════════════════════════════════════════════════
       AUTOMATED BOUNDARY
       ══════════════════════════════════════════════════════════════ */

    subgraph cluster_automated {
        label="\n▸  AUTOMATED — Orchestrated by Dagster\n ";
        labeljust=l;
        style="rounded,bold";
        color="#F57F17";
        fontsize=14;
        fontcolor="#F57F17";
        penwidth=3;
        margin=20;

        /* ── RANK 3: Staging ── */
        staging [label="Staging Models (9 + 1) — dbt/models/staging/\nAll STRING → typed casts · SAFE_CAST for nullable fields\nsources.yml: 9 tables with _view suffix",
                 fillcolor="#C8E6C9", color="#43A047"];

        /* ── RANK 4: Marts ── */
        marts [label="Mart Models — dbt/models/marts/\n4 dims: customers · products · sellers · date\n3 facts: sales · reviews · payments",
               fillcolor="#C8E6C9", color="#43A047"];

        /* ── Quality cluster ── */
        subgraph cluster_quality {
            label="Data Quality (dbt test)";
            labeljust=l;
            style="rounded,filled";
            fillcolor="#F1F8E9";
            color="#AED581";
            fontsize=11;
            fontcolor="#558B2F";
            margin=15;

            expectations [label="dbt-expectations\nGeneric tests in schema.yml\nnull thresholds · ranges\nrow counts · temporal pairs",
                          fillcolor="#DCEDC8", color="#7CB342"];
            singular [label="Singular Tests (3 SQL)\nboleto installments\npayment reconciliation\ndate_key range",
                      fillcolor="#DCEDC8", color="#7CB342"];
            dbt_utils [label="dbt_utils\ndate_spine → dim_date\nunique_combination_of_columns",
                       fillcolor="#DCEDC8", color="#7CB342"];
        }

        /* ── Dagster ── */
        dagster [label="Dagster — dagster/\nAsset Graph · 25 assets\n@multi_asset + @dbt_assets\nmeltano_ingest → stg_* → dim_*/fct_*\nSchedule: daily 09:00 SGT · Trigger: UI + CLI",
                 fillcolor="#FFECB3", color="#FFB300"];
    }

    /* ══════════════════════════════════════════════════════════════
       RANK 5: BigQuery Analytics
       ══════════════════════════════════════════════════════════════ */

    analytics [label="BigQuery · olist_analytics · Star Schema\n~112k order-items · ~96k customers · ~100k reviews",
               fillcolor="#C5CAE9", color="#7986CB"];

    /* ══════════════════════════════════════════════════════════════
       MANUAL BOUNDARY
       ══════════════════════════════════════════════════════════════ */

    subgraph cluster_manual {
        label="\n▸  MANUAL — Not orchestrated by Dagster\n ";
        labeljust=l;
        style="rounded,bold";
        color="#7B1FA2";
        fontsize=14;
        fontcolor="#7B1FA2";
        penwidth=3;
        margin=20;

        /* ── RANK 6: Analysis ── */
        notebooks [label="Analysis — notebooks/\nJupyter Notebooks (4): 00_eda · 01_sales · 02_customer · 03_geo_seller\n+ utils.py · Queries via google.cloud.bigquery",
                   fillcolor="#E1BEE7", color="#8E24AA"];

        /* ── RANK 7: Data Export ── */
        parquet [label="Data Export — data/ · Parquet Files (6) · ~308k rows\nsales_orders (112,279) · customer_rfm (95,420) · satisfaction_summary (97,379)\ngeo_delivery (533) · seller_performance (3,068) · concentration_metrics (83)",
                 fillcolor="#B2EBF2", color="#00ACC1"];

        /* ── RANK 8: Presentation ── */
        streamlit [label="Streamlit Dashboard — streamlit/\n5 pages: Executive · Products · Geographic · Customers · Glossary\n4 global filters: Date Range · Product Category · Customer State · Region",
                   fillcolor="#F8BBD0", color="#E91E63"];
        brief [label="Executive Brief\ndocs/executive_brief.md",
               fillcolor="#F8BBD0", color="#E91E63"];
    }

    /* ── Scripts ── */
    launch [label="scripts/launch_dagster.sh\n7 pre-flight checks", fillcolor="#F5F5F5", color="#999999"];
    genparquet [label="scripts/generate_parquet.py\nalternative to notebooks", fillcolor="#F5F5F5", color="#999999"];

    /* ══════════════════════════════════════════════════════════════
       EDGES — Primary data flow
       ══════════════════════════════════════════════════════════════ */

    csv -> meltano [label="  ingest  ", penwidth=3, color="#E65100"];
    meltano -> raw [label="  load  ", penwidth=3, color="#1565C0"];
    raw -> staging [label="  source()  ", penwidth=3, color="#2E7D32"];
    staging -> marts [label="  ref()  ", penwidth=3, color="#2E7D32"];
    marts -> analytics [label="  materialise  ", penwidth=3, color="#1565C0"];
    analytics -> notebooks [label="  SQL queries  ", penwidth=3, color="#7B1FA2"];
    notebooks -> parquet [label="  export  ", penwidth=3, color="#00838F"];
    parquet -> streamlit [label="  read  ", penwidth=3, color="#C62828"];
    notebooks -> brief [label="  insights  ", penwidth=2, color="#C62828"];

    /* ══════════════════════════════════════════════════════════════
       EDGES — Quality / validation
       ══════════════════════════════════════════════════════════════ */

    dbt_utils -> marts [style=dashed, color="#7CB342", label="  macros  "];
    staging -> expectations [style=dashed, color="#7CB342", label="  validates  "];
    marts -> expectations [style=dashed, color="#7CB342", label="  validates  "];
    marts -> singular [style=dashed, color="#7CB342", label="  validates  "];

    /* ══════════════════════════════════════════════════════════════
       EDGES — Dagster orchestration
       ══════════════════════════════════════════════════════════════ */

    dagster -> meltano [style=dashed, color="#F57F17", label="  orchestrates  ", penwidth=2];
    dagster -> staging [style=dashed, color="#F57F17", label="  dbt build  ", penwidth=2];

    /* ══════════════════════════════════════════════════════════════
       EDGES — Credentials (.env)
       ══════════════════════════════════════════════════════════════ */

    env -> meltano [style=dotted, color="#8D6E63", penwidth=1.5];
    env -> dagster [style=dotted, color="#8D6E63", penwidth=1.5];
    env -> staging [style=dotted, color="#8D6E63", penwidth=1.5];
    env -> notebooks [style=dotted, color="#8D6E63", penwidth=1.5];

    /* ══════════════════════════════════════════════════════════════
       EDGES — Scripts
       ══════════════════════════════════════════════════════════════ */

    launch -> dagster [style=dashed, color="#999999", label="  launches  "];
    genparquet -> parquet [style=dashed, color="#999999", label="  alternative export  "];
}
