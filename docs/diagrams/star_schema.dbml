// Star Schema ERD — Project Caravela
// Paste into dbdiagram.io to render interactively
// Dataset: olist_analytics (BigQuery)

Table dim_customers {
  customer_unique_id STRING [pk, note: "Deduplicated on customer_unique_id via ROW_NUMBER"]
  customer_city STRING
  customer_state STRING
  customer_zip_code_prefix STRING
  geolocation_lat FLOAT64 [note: "Nullable — LEFT JOIN stg_geolocation by zip"]
  geolocation_lng FLOAT64 [note: "Nullable — LEFT JOIN stg_geolocation by zip"]
}

Table dim_products {
  product_id STRING [pk]
  product_category_name_english STRING [note: "COALESCE: english → portuguese → uncategorized"]
  product_name_length INT64 [note: "Nullable — SAFE_CAST returns NULL for empty source strings"]
  product_description_length INT64 [note: "Nullable — SAFE_CAST returns NULL for empty source strings"]
  product_photos_qty INT64 [note: "Nullable — SAFE_CAST"]
  product_weight_g INT64 [note: "Nullable — SAFE_CAST"]
  product_length_cm INT64 [note: "Nullable — SAFE_CAST"]
  product_height_cm INT64 [note: "Nullable — SAFE_CAST"]
  product_width_cm INT64 [note: "Nullable — SAFE_CAST"]
}

Table dim_sellers {
  seller_id STRING [pk]
  seller_city STRING
  seller_state STRING
  seller_zip_code_prefix STRING
  geolocation_lat FLOAT64 [note: "Nullable — LEFT JOIN stg_geolocation by zip"]
  geolocation_lng FLOAT64 [note: "Nullable — LEFT JOIN stg_geolocation by zip"]
}

Table dim_date {
  date_key DATE [pk, note: "Generated by dbt_utils.date_spine (2016-01-01 to 2018-12-31)"]
  year INT64
  month INT64
  day INT64
  day_of_week INT64
  quarter INT64
}

Table fct_sales {
  order_id STRING [pk, note: "Compound PK: order_id + order_item_id"]
  order_item_id INT64 [pk]
  product_id STRING [ref: > dim_products.product_id]
  seller_id STRING [ref: > dim_sellers.seller_id]
  customer_unique_id STRING [ref: > dim_customers.customer_unique_id, note: "3-source resolution: items → orders → customers"]
  date_key DATE [ref: > dim_date.date_key]
  order_status STRING
  price FLOAT64
  freight_value FLOAT64
  total_sale_amount FLOAT64 [note: "= price + freight_value"]
  order_delivered_customer_date TIMESTAMP [note: "Nullable"]
  order_estimated_delivery_date TIMESTAMP [note: "Nullable"]
}

Table fct_reviews {
  review_id STRING [pk, note: "Deduplicated in stg_reviews (789 dupes removed)"]
  order_id STRING [note: "FK → stg_orders (NOT fct_sales) — 756 itemless orders have reviews but no fct_sales rows"]
  review_score INT64
  review_comment_title STRING [note: "Nullable — fill rate ~11.7%"]
  review_comment_message STRING [note: "Nullable — fill rate ~41.3%"]
  date_key DATE [ref: > dim_date.date_key]
  review_answer_timestamp TIMESTAMP
}

Table fct_payments {
  order_id STRING [pk, note: "Compound PK: order_id + payment_sequential"]
  payment_sequential INT64 [pk]
  payment_type STRING
  payment_installments INT64
  payment_value FLOAT64
  date_key DATE [ref: > dim_date.date_key, note: "Nullable — LEFT JOIN stg_orders; NULL when order missing"]
}

// Staging table included because fct_reviews.order_id crosses the mart/staging
// boundary — the only such FK in the project. See ADR-003 for rationale.
Table stg_orders {
  order_id STRING [pk]
  customer_id STRING
  order_status STRING
  order_purchase_timestamp TIMESTAMP
  date_key DATE [note: "DATE(order_purchase_timestamp) — used by fct_sales and fct_payments"]

  Note: '''
    Staging model — included in ERD solely as the FK target for fct_reviews.order_id.
    756 orders have reviews but no line items (itemless orders), so the FK cannot
    target fct_sales. See ADR-003.
  '''
}

// Cross-boundary FK: fct_reviews.order_id → stg_orders.order_id (NOT fct_sales)
Ref: fct_reviews.order_id > stg_orders.order_id